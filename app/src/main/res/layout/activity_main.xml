<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_purple">

    <!-- World background -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/world"
        android:scaleType="centerCrop"
        android:alpha="0.2"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            android:paddingTop="52dp"
            android:paddingBottom="24dp">

            <!-- Profile Header -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/iv_profile"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:scaleType="centerCrop"
                    android:src="@drawable/profile"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:shapeAppearanceOverlay="@style/ShapeAppearance.App.Circle" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:orientation="vertical"
                    app:layout_constraintBottom_toBottomOf="@id/iv_profile"
                    app:layout_constraintEnd_toStartOf="@id/iv_bell"
                    app:layout_constraintStart_toEndOf="@id/iv_profile"
                    app:layout_constraintTop_toTopOf="@id/iv_profile">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Good morning,"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="13sp"
                        android:fontFamily="@font/outfit_regular" />

                    <TextView
                        android:id="@+id/tv_greeting"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Traveller"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/outfit_bold" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_bell"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:padding="10dp"
                    android:src="@drawable/bell_icon"
                    app:layout_constraintBottom_toBottomOf="@id/iv_profile"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/iv_profile" />
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Airplane banner image -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="190dp"
                android:layout_marginTop="24dp"
                android:src="@drawable/splash_bg"
                android:scaleType="centerCrop"
                android:adjustViewBounds="true"
                android:background="@drawable/bg_rounded_card"
                android:clipToOutline="true" />

            <!-- Search Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/bg_light_purple"
                app:cardCornerRadius="28dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- From -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="FROM"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/outfit_bold" />

                    <AutoCompleteTextView
                        android:id="@+id/et_from_city"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_search_field"
                        android:drawableStart="@drawable/from_ic"
                        android:drawablePadding="12dp"
                        android:hint="e.g. New York"
                        android:padding="16dp"
                        android:text="New York"
                        android:textColor="@color/white"
                        android:textColorHint="@color/colorTextSecondary"
                        android:textSize="16sp"
                        android:fontFamily="@font/outfit_medium"
                        android:completionThreshold="1" />

                    <!-- To -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="TO"
                        android:textColor="@color/colorTextSecondary"
                        android:textSize="11sp"
                        android:letterSpacing="0.1"
                        android:fontFamily="@font/outfit_bold" />

                    <AutoCompleteTextView
                        android:id="@+id/et_to_city"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:layout_marginTop="6dp"
                        android:background="@drawable/bg_search_field"
                        android:drawableStart="@drawable/to_ic"
                        android:drawablePadding="12dp"
                        android:hint="e.g. Los Angeles"
                        android:padding="16dp"
                        android:text="Los Angeles"
                        android:textColor="@color/white"
                        android:textColorHint="@color/colorTextSecondary"
                        android:textSize="16sp"
                        android:fontFamily="@font/outfit_medium"
                        android:completionThreshold="1" />

                    <!-- Passengers Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="PASSENGERS"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:fontFamily="@font/outfit_bold" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_search_field"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="12dp"
                                android:orientation="horizontal">

                                <ImageView
                                    android:id="@+id/btn_pax_minus"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/bg_search_btn"
                                    android:padding="6dp"
                                    android:src="@drawable/back"
                                    android:scaleX="-1"
                                    android:rotation="180" />

                                <TextView
                                    android:id="@+id/tv_pax_count"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:gravity="center"
                                    android:text="1"
                                    android:textColor="@color/white"
                                    android:textSize="18sp"
                                    android:textStyle="bold"
                                    android:fontFamily="@font/outfit_bold" />

                                <ImageView
                                    android:id="@+id/btn_pax_plus"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:background="@drawable/bg_search_btn"
                                    android:padding="6dp"
                                    android:src="@drawable/back"
                                    android:rotation="0" />
                            </LinearLayout>
                        </LinearLayout>

                        <View android:layout_width="12dp" android:layout_height="1dp" />

                        <!-- Class Selector -->
                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="CLASS"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:fontFamily="@font/outfit_bold" />

                            <LinearLayout
                                android:id="@+id/btn_class_selector"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_search_field"
                                android:gravity="center_vertical"
                                android:paddingHorizontal="12dp"
                                android:orientation="horizontal"
                                android:clickable="true"
                                android:focusable="true">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/seat_black_ic" />

                                <TextView
                                    android:id="@+id/tv_class"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:layout_marginStart="8dp"
                                    android:text="Economy"
                                    android:textColor="@color/white"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit_bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Dates Row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="DEPART"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:fontFamily="@font/outfit_bold" />

                            <LinearLayout
                                android:id="@+id/btn_depart_date"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_search_field"
                                android:gravity="center_vertical"
                                android:padding="12dp"
                                android:orientation="horizontal"
                                android:clickable="true"
                                android:focusable="true">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/calendar_ic" />

                                <TextView
                                    android:id="@+id/tv_depart_date"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="3 Jun 2024"
                                    android:textColor="@color/white"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit_bold" />
                            </LinearLayout>
                        </LinearLayout>

                        <View android:layout_width="12dp" android:layout_height="1dp" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="RETURN"
                                android:textColor="@color/colorTextSecondary"
                                android:textSize="11sp"
                                android:letterSpacing="0.1"
                                android:fontFamily="@font/outfit_bold" />

                            <LinearLayout
                                android:id="@+id/btn_return_date"
                                android:layout_width="match_parent"
                                android:layout_height="56dp"
                                android:layout_marginTop="6dp"
                                android:background="@drawable/bg_search_field"
                                android:gravity="center_vertical"
                                android:padding="12dp"
                                android:orientation="horizontal"
                                android:clickable="true"
                                android:focusable="true">

                                <ImageView
                                    android:layout_width="20dp"
                                    android:layout_height="20dp"
                                    android:src="@drawable/calendar_ic" />

                                <TextView
                                    android:id="@+id/tv_return_date"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:layout_marginStart="8dp"
                                    android:text="8 Jun 2024"
                                    android:textColor="@color/white"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit_bold" />
                            </LinearLayout>
                        </LinearLayout>
                    </LinearLayout>

                    <!-- Search Button -->
                    <FrameLayout
                        android:id="@+id/btn_search_flights"
                        android:layout_width="match_parent"
                        android:layout_height="64dp"
                        android:layout_marginTop="24dp"
                        android:background="@drawable/bg_search_btn"
                        android:clickable="true"
                        android:focusable="true">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:text="🔍  Search Flights"
                            android:textColor="@color/white"
                            android:textSize="18sp"
                            android:textStyle="bold"
                            android:fontFamily="@font/outfit_bold" />
                    </FrameLayout>

                    <!-- Recommendations Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="32dp"
                        android:text="Recommended for you"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/outfit_bold" />

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rv_recommendations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:clipToPadding="false"
                        android:orientation="horizontal"
                        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                    <!-- Trending Section -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Trending Destinations"
                        android:textColor="@color/white"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:fontFamily="@font/outfit_bold" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="120dp"
                        android:layout_marginTop="12dp"
                        app:cardBackgroundColor="#211244"
                        app:cardCornerRadius="20dp"
                        app:cardElevation="0dp">

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">

                            <ImageView
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:alpha="0.4"
                                android:src="@drawable/world" />

                            <LinearLayout
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="20dp"
                                android:orientation="vertical">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Explore Dubai"
                                    android:textColor="@color/white"
                                    android:textSize="18sp"
                                    android:fontFamily="@font/outfit_bold" />

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Save up to 30% this week"
                                    android:textColor="@color/colorTextSecondary"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/outfit_regular" />
                            </LinearLayout>

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:layout_marginEnd="20dp"
                                android:background="@drawable/bg_status_badge"
                                android:paddingHorizontal="12dp"
                                android:paddingVertical="6dp"
                                android:text="NEW"
                                android:textColor="#00E676"
                                android:textSize="11sp"
                                android:textStyle="bold" />
                        </RelativeLayout>
                    </androidx.cardview.widget.CardView>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#15082E"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="8dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <ImageView
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@drawable/bottom_btn1" />

        <ImageView
            android:id="@+id/nav_search"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@drawable/bottom_btn2" />

        <ImageView
            android:id="@+id/nav_bookings"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@drawable/bottom_btn3" />

        <ImageView
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:padding="18dp"
            android:src="@drawable/bottom_btn4" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
