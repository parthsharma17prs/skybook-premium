<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_deep_purple">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/world"
        android:scaleType="centerCrop"
        android:alpha="0.2" />

    <LinearLayout
        android:id="@+id/ll_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="32dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_auth_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome\nBack!"
            android:textColor="@color/white"
            android:textSize="36sp"
            android:textStyle="bold"
            android:fontFamily="@font/outfit_bold" />

        <TextView
            android:id="@+id/tv_auth_subtitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Login to continue your journey"
            android:textColor="@color/colorTextSecondary"
            android:textSize="16sp"
            android:fontFamily="@font/outfit_regular" />
    </LinearLayout>

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_auth"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:layout_marginTop="32dp"
        app:cardBackgroundColor="@color/bg_light_purple"
        app:cardCornerRadius="32dp"
        app:cardElevation="0dp"
        app:layout_constraintTop_toBottomOf="@id/ll_title">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <EditText
                android:id="@+id/et_name"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:background="@drawable/bg_rounded_card"
                android:backgroundTint="#2A144E"
                android:hint="Full Name"
                android:paddingHorizontal="20dp"
                android:textColor="@color/white"
                android:textColorHint="@color/colorTextSecondary"
                android:visibility="gone" />

            <EditText
                android:id="@+id/et_email"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_rounded_card"
                android:backgroundTint="#2A144E"
                android:hint="Email Address"
                android:paddingHorizontal="20dp"
                android:textColor="@color/white"
                android:textColorHint="@color/colorTextSecondary" />

            <EditText
                android:id="@+id/et_password"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_rounded_card"
                android:backgroundTint="#2A144E"
                android:hint="Password"
                android:inputType="textPassword"
                android:paddingHorizontal="20dp"
                android:textColor="@color/white"
                android:textColorHint="@color/colorTextSecondary" />

            <FrameLayout
                android:id="@+id/btn_auth_action"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:background="@drawable/bg_search_btn"
                android:clickable="true"
                android:focusable="true">

                <TextView
                    android:id="@+id/tv_auth_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:text="Login"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/outfit_bold" />
            </FrameLayout>

            <TextView
                android:id="@+id/tv_toggle_auth"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="24dp"
                android:text="Don't have an account? Sign Up"
                android:textColor="@color/accent_pink"
                android:textSize="14sp"
                android:fontFamily="@font/outfit_medium" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>
