<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="12dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/bg_light_purple"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Airline info row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/iv_airline_logo"
                android:layout_width="80dp"
                android:layout_height="36dp"
                android:src="@drawable/delta_airline"
                android:scaleType="fitCenter" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_class_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Economy"
                android:textColor="@color/white"
                android:textSize="11sp"
                android:fontFamily="@font/outfit_bold" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_airline_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Delta Airlines"
            android:textColor="@color/colorTextSecondary"
            android:textSize="12sp"
            android:fontFamily="@font/outfit_medium" />

        <!-- Route row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <!-- From -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_depart_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="08:00"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/outfit_bold" />
                <TextView
                    android:id="@+id/tv_from_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JFK"
                    android:textColor="@color/accent_pink"
                    android:textSize="13sp"
                    android:fontFamily="@font/outfit_bold" />
                <TextView
                    android:id="@+id/tv_from_city"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New York"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp"
                    android:fontFamily="@font/outfit_medium" />
            </LinearLayout>

            <!-- Duration / plane line -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical"
                android:paddingHorizontal="8dp">

                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="6h 30m"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp"
                    android:fontFamily="@font/outfit_medium" />

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="20dp"
                    android:src="@drawable/line_airple_blue"
                    android:scaleType="fitCenter"
                    android:layout_marginTop="4dp" />
            </LinearLayout>

            <!-- To -->
            <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content" android:gravity="end" android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_arrive_time"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="14:30"
                    android:textColor="@color/white"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/outfit_bold" />
                <TextView
                    android:id="@+id/tv_to_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LAX"
                    android:textColor="@color/accent_pink"
                    android:textSize="13sp"
                    android:fontFamily="@font/outfit_bold" />
                <TextView
                    android:id="@+id/tv_to_city"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Los Angeles"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="11sp"
                    android:fontFamily="@font/outfit_medium" />
            </LinearLayout>
        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:background="#20FFFFFF" />

        <!-- Price row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Select Seat →"
                android:textColor="@color/colorTextSecondary"
                android:textSize="13sp"
                android:fontFamily="@font/outfit_medium" />

            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$320"
                android:textColor="@color/accent_yellow"
                android:textSize="22sp"
                android:textStyle="bold"
                android:fontFamily="@font/outfit_bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
