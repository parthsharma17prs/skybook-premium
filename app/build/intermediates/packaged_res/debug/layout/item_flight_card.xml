<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginTop="16dp"
    android:layout_marginBottom="8dp"
    android:clickable="true"
    android:focusable="true"
    app:cardBackgroundColor="@color/bg_light_purple"
    app:cardCornerRadius="28dp"
    app:cardElevation="0dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/iv_airline_logo"
            android:layout_width="140dp"
            android:layout_height="48dp"
            android:layout_gravity="center_horizontal"
            android:src="@drawable/delta_airline"
            android:scaleType="fitCenter" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:orientation="horizontal"
            android:paddingHorizontal="24dp">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_from_city"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="New York"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/outfit_medium" />
                <TextView
                    android:id="@+id/tv_from_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="JFK"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/outfit_bold" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">
                 <ImageView
                    android:layout_width="120dp"
                    android:layout_height="24dp"
                    android:src="@drawable/line_airple_blue"
                    android:scaleType="fitCenter" />
                <TextView
                    android:id="@+id/tv_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="2h 45m"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/outfit_medium" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="end"
                android:orientation="vertical">
                <TextView
                    android:id="@+id/tv_to_city"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Los Angeles"
                    android:textColor="@color/colorTextSecondary"
                    android:textSize="12sp"
                    android:fontFamily="@font/outfit_medium" />
                <TextView
                    android:id="@+id/tv_to_code"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="LAX"
                    android:textColor="@color/white"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:fontFamily="@font/outfit_bold" />
            </LinearLayout>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="20dp"
            android:background="#20FFFFFF" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="16dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/seat_black_ic"
                app:tint="@color/accent_yellow" />

            <TextView
                android:id="@+id/tv_class_type"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:text="Business class"
                android:textColor="@color/accent_yellow"
                android:textSize="14sp"
                android:fontFamily="@font/outfit_bold" />

            <TextView
                android:id="@+id/tv_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="$169.00"
                android:textColor="@color/accent_yellow"
                android:textSize="18sp"
                android:fontFamily="@font/outfit_bold" />
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
